# LLM Providers — configure one or both. Models from each configured
# provider appear in the UI dropdown.
OPENROUTER_API_KEY=sk-or-...
# HERMES_API_KEY=sk-...        # Direct Nous Research inference (portal.nousresearch.com)

# Hermes agent settings
# LLM_MODEL=nousresearch/hermes-3-llama-3.1-405b   # default model on startup
# HERMES_MAX_ITERATIONS=10

# Optional: web search/scrape (enables agent web tools)
# FIRECRAWL_API_KEY=fc-...

# Optional: image generation via fal.ai
# FAL_KEY=...

# Optional: Elephantasm long-term agentic memory
# ELEPHANTASM_API_KEY=sk_live_...
# ELEPHANTASM_ANIMA_ID=anima_...
